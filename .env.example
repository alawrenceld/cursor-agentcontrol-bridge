# LaunchDarkly server-side SDK key for the environment where metrics should land.
LD_SDK_KEY=sdk-...

# Cursor Admin API key (Teams/Business/Enterprise only). Used by the poller.
# Create at cursor.com dashboard -> Settings -> Advanced -> Admin API Keys.
CURSOR_ADMIN_KEY=key_...

# --- Optional: only needed for scripts/setup-ai-config.mjs ---
# LaunchDarkly REST API access token (writer role on the project).
LD_API_TOKEN=api-...
# LaunchDarkly project key where the AI Config lives.
LD_PROJECT_KEY=default

# Set to 1 to log events instead of sending them to LaunchDarkly.
# DRY_RUN=1
