{
  "name": "cursor-agentcontrol-metrics",
  "displayName": "AgentControl Metrics",
  "description": "LaunchDarkly AI Config Monitoring metrics for Cursor agent usage, inside the IDE",
  "version": "0.4.0",
  "publisher": "alawrenceld",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ldAgentControl",
          "title": "AgentControl",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ldAgentControl": [
        {
          "type": "webview",
          "id": "ldAgentControl.metrics",
          "name": "Cursor Usage · LaunchDarkly"
        }
      ]
    },
    "commands": [
      {
        "command": "ldAgentControl.refresh",
        "title": "AgentControl: Refresh Metrics"
      },
      {
        "command": "ldAgentControl.setToken",
        "title": "AgentControl: Set LaunchDarkly API Token (read metrics)"
      },
      {
        "command": "ldAgentControl.setSdkKey",
        "title": "AgentControl: Set LaunchDarkly SDK Key (record agent runs)"
      },
      {
        "command": "ldAgentControl.setIdentity",
        "title": "AgentControl: Set Your Email (Me filter identity)"
      },
      {
        "command": "ldAgentControl.openHookConfig",
        "title": "AgentControl: Open Hook Config (ld-agentcontrol.json)"
      }
    ],
    "configuration": {
      "title": "AgentControl Metrics",
      "properties": {
        "ldAgentControl.projectKey": {
          "type": "string",
          "default": "",
          "description": "LaunchDarkly project key that holds your AI Config (create your own; do not share SDK keys across orgs)"
        },
        "ldAgentControl.configKey": {
          "type": "string",
          "default": "cursor-agent-usage",
          "description": "AI Config key whose Monitoring metrics to display"
        },
        "ldAgentControl.environmentKey": {
          "type": "string",
          "default": "production",
          "description": "LaunchDarkly environment key"
        },
        "ldAgentControl.pollSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "How often to refresh metrics from LaunchDarkly"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
