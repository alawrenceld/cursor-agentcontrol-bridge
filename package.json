{
  "name": "cursor-agentcontrol-bridge",
  "version": "0.2.0",
  "description": "Bridge Cursor IDE agent activity (hooks + Admin API) into LaunchDarkly AI Config Monitoring",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "hook:test": "sh scripts/hook-test.sh",
    "poller:dry": "node src/poller/poll-usage-events.mjs --dry-run",
    "poller:once": "node src/poller/poll-usage-events.mjs",
    "poller:loop": "node src/poller/poll-usage-events.mjs --loop",
    "setup:ai-config": "node scripts/setup-ai-config.mjs",
    "sync:models": "node scripts/sync-model-library.mjs",
    "setup:claude-ai-config": "node scripts/setup-claude-ai-config.mjs",
    "sync:claude-models": "node scripts/sync-claude-model-library.mjs",
    "install:claude-hooks": "node scripts/install-claude-hooks.mjs",
    "install:menubar": "node scripts/install-menubar.mjs",
    "menubar": "node scripts/agent-menubar.mjs",
    "agent:usage": "node scripts/agent-usage-report.mjs",
    "claude:usage": "node scripts/agent-usage-report.mjs",
    "build:hook": "node scripts/build-hook.mjs",
    "spike:me-remote": "node scripts/spike-me-remote.mjs",
    "report:export": "node scripts/export-usage-summary.mjs",
    "report:serve": "node scripts/serve-report.mjs"
  },
  "dependencies": {
    "@launchdarkly/node-server-sdk": "^9.11.3"
  },
  "devDependencies": {
    "@launchdarkly/server-sdk-ai": "^1.1.1",
    "esbuild": "^0.28.1"
  }
}
