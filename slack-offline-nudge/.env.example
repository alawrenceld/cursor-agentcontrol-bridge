# Bot User OAuth Token from https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Comma-separated Slack user IDs to watch (U… / W…).
# Leave empty to watch every non-bot human in the workspace.
WATCH_USER_IDS=

# How often to poll presence (ms). Slack rate-limits users.getPresence — keep ≥ 15000 for small teams.
POLL_INTERVAL_MS=20000

# Minimum time between nudges to the same person (ms). Default: 30 minutes.
NUDGE_COOLDOWN_MS=1800000

# Message sent when someone flips active → away
NUDGE_MESSAGE=any updates?

# Set to 1 to log presence checks without sending DMs
DRY_RUN=0
